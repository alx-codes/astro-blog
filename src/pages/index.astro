---
import BaseLayoutAstroComponent from "../layouts/BaseLayout.astro";
import Greeting from "../components/Greeting";
const pageTitle = "Home Page";
---

<BaseLayoutAstroComponent pageTitle={pageTitle}>
  <h2>{pageTitle}</h2>
  <Greeting client:load messages={["Hi", "Hello", "Howdy", "Hey there"]} />
</BaseLayoutAstroComponent>
