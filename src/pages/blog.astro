---
import BaseLayoutAstroComponent from "../layouts/BaseLayout.astro";
import BlogPostAstroComponent from "../components/BlogPost.astro";
import "../styles/global.css";

const allPosts = Object.values(
  import.meta.glob("./posts/*.md", { eager: true }),
);
const pageTitle = "My Astro Learning Blog";
---

<BaseLayoutAstroComponent pageTitle={pageTitle}>
  <p>This is where I will post about my journey learning Astro.</p>
  <ul>
    {
      allPosts.map((post: any) => (
        <BlogPostAstroComponent url={post.url} title={post.frontmatter.title} />
      ))
    }
  </ul>
</BaseLayoutAstroComponent>
