---
import { getCollection } from "astro:content";
import BaseLayoutAstroComponent from "../../layouts/BaseLayout.astro";

// get all markdown posts
const allPosts = await getCollection("blog");

// create a flat array of unique tags from all posts
const tags = [...new Set(allPosts.map((post: any) => post.data.tags).flat())];

const pageTitle = "Blog Tags";
---

<BaseLayoutAstroComponent pageTitle={pageTitle}>
  <div class="tags">
    {
      tags.map((tag) => (
        <p>
          <a href={`/tags/${tag}/`}>{tag}</a>
        </p>
      ))
    }
  </div>
</BaseLayoutAstroComponent>
